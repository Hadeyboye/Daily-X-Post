# daily_x_posts Environment Configuration
# Copy to .env and fill in your secrets. NEVER commit .env

# === Core LLM / Novita AI (Primary provider for sandbox) ===
NOVITA_API_KEY=sk-novita-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOVITA_BASE_URL=https://api.novita.ai/v3
NOVITA_DEFAULT_MODEL=meta-llama/Llama-3.1-70B-Instruct  # or other available
NOVITA_IMAGE_MODEL=flux-1/schnell  # or flux-1/dev, etc.
NOVITA_VIDEO_MODEL=stable-video-diffusion  # or platform video model id

# === X / Twitter API v2 (Essential for real posting) ===
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret
X_BEARER_TOKEN=your_bearer_token

# Optional: X App ID for advanced features
X_CLIENT_ID=
X_CLIENT_SECRET=

# === LangSmith Observability (Highly Recommended) ===
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__your_langsmith_key
LANGSMITH_PROJECT=daily_x_posts
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# === Storage / Persistence ===
CHROMA_PERSIST_DIR=./chroma_db
SQLITE_DB_PATH=./data/daily_x_posts.db
OUTPUTS_DIR=./outputs

# === Scheduling & Autonomy ===
AUTONOMY_ENABLED=true
RESEARCH_INTERVAL_HOURS=6
POSTING_WINDOW_START=08:00
POSTING_WINDOW_END=22:00
TIMEZONE=America/New_York

# === Safety & Guardrails ===
SAFETY_ENABLED=true
MAX_DAILY_POSTS=8
CONTENT_FILTER_LEVEL=medium  # low|medium|high

# === Multi-platform (future expansion, stubs ready) ===
LINKEDIN_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# === Human-in-the-Loop ===
APPROVAL_REQUIRED=true  # Set false for full autonomy (use with care)
SLACK_WEBHOOK_URL=  # For escalation notifications (optional)

# === Misc ===
LOG_LEVEL=INFO
DEBUG=false
SEED=42
